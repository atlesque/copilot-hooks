# ntfy.sh server URL (optional — leave empty to disable all notifications)
# e.g. NTFY_SERVER="https://ntfy.sh"
NTFY_SERVER=""

# ntfy.sh topic name (optional — leave empty to disable all notifications)
# e.g. NTFY_TOPIC="your-topic"
NTFY_TOPIC=""

# ntfy.sh access token (optional — leave empty if your ntfy server doesn't require auth)
# e.g. NTFY_TOKEN="tk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NTFY_TOKEN=""
